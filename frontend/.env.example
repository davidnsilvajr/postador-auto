# Frontend - variaveis de ambiente (Vite)
# Copie para .env e ajuste.

# URL do backend. Em dev pode deixar vazio (o Vite faz proxy de /api para :8000).
# Em producao, aponte para a URL do backend, ex: https://api.seudominio.com
VITE_API_URL=

# Supabase (obrigatorio para autenticacao)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
