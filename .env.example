# Postador Auto - Environment Variables
# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (gerencia todas as IAs - Claude, GPT, etc.)
OPENROUTER_API_KEY=sk-or-...

# Modelos padrao via OpenRouter (opcionais - pode usar os defaults)
OPENROUTER_TEXT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# OpenAI direto (fallback para geracao de imagens com DALL-E 3)
# Usado apenas se o Gemini falhar. Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# URL direta do banco PostgreSQL (necessaria para rodar migrations)
# Obtenha em: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[senha]@db.[project-ref].supabase.co:5432/postgres

# Social Media API Tokens
# INSTAGRAM: para publicar direto, voce precisa de:
#   1) Conta Instagram Business/Creator vinculada a uma Pagina do Facebook
#   2) App no Meta for Developers (https://developers.facebook.com)
#   3) Token de acesso com escopos: instagram_basic, instagram_content_publish, pages_show_list
#   4) O "IG Business Account ID" (page_id) da conta
# O token/ID podem ser informados por conta na tela de Integracoes (recomendado),
# ou como fallback global aqui:
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
YOUTUBE_ACCESS_TOKEN=

# CORS (separado por virgula). O Vite roda em 5173 por padrao.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
